# Gemini API Key (Required to run the agents)
# Retrieve your key from Google AI Studio: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Server Configuration (for email notifications and applications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True

# Recipient email for job match alerts
NOTIFICATION_RECEIVER=your_email@gmail.com

# Auto Apply Settings
AUTO_APPLY_ENABLED=False
AUTO_APPLY_THRESHOLD=85
