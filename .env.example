# Gemini API Key (Required to run the agents)
# Retrieve your key from Google AI Studio: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Server Configuration (configured for local Mailpit container)
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USERNAME=mock
SMTP_PASSWORD=mock
SMTP_USE_TLS=False

# Recipient email for job match alerts
NOTIFICATION_RECEIVER=my-alerts@example.com

# Auto Apply Settings
AUTO_APPLY_ENABLED=False
AUTO_APPLY_THRESHOLD=85
